{{ 'section-premium-fashion-hero.css' | asset_url | stylesheet_tag }}

<section
  class="premium-fashion-hero"
  data-section-id="{{ section.id }}"
  data-section-type="premium-fashion-hero"
  data-animation-enabled="{{ section.settings.enable_animations }}"
  style="--hero-surface: {{ section.settings.background_color | default: '#f7efe7' }}; --hero-accent: {{ section.settings.accent_color | default: '#b68c4b' }}; --hero-overlay-color: {{ section.settings.overlay_color | default: '#000000' }}; --hero-overlay-opacity: {{ section.settings.overlay_opacity | default: 0.18 }}; --hero-padding-top: {{ section.settings.padding_top | default: 72 }}px; --hero-padding-bottom: {{ section.settings.padding_bottom | default: 72 }}px; --hero-height: {{ section.settings.hero_height | default: 720 }}px;"
>
  <div class="premium-fashion-hero__backdrop" aria-hidden="true"></div>

  <div class="premium-fashion-hero__container">
    <div class="premium-fashion-hero__grid">
      <div class="premium-fashion-hero__content premium-fashion-hero__content--{{ section.settings.content_alignment | default: 'left' }}">
        {% if section.settings.eyebrow != blank %}
          <p class="premium-fashion-hero__eyebrow reveal reveal--item">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h1 class="premium-fashion-hero__heading reveal reveal--item">{{ section.settings.heading }}</h1>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <p class="premium-fashion-hero__subheading reveal reveal--item">{{ section.settings.subheading }}</p>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="premium-fashion-hero__description reveal reveal--item">{{ section.settings.description }}</div>
        {% endif %}

        {% if section.settings.primary_button_label != blank or section.settings.secondary_button_label != blank %}
          <div class="premium-fashion-hero__actions reveal reveal--item">
            {% if section.settings.primary_button_label != blank and section.settings.primary_button_link != blank %}
              <a class="premium-fashion-hero__button premium-fashion-hero__button--primary js-magnetic" href="{{ section.settings.primary_button_link }}">
                <span>{{ section.settings.primary_button_label }}</span>
              </a>
            {% endif %}

            {% if section.settings.secondary_button_label != blank and section.settings.secondary_button_link != blank %}
              <a class="premium-fashion-hero__button premium-fashion-hero__button--secondary" href="{{ section.settings.secondary_button_link }}">
                <span>{{ section.settings.secondary_button_label }}</span>
              </a>
            {% endif %}
          </div>
        {% endif %}

        {% if section.settings.highlight_text != blank %}
          <div class="premium-fashion-hero__floating-badge reveal reveal--item">{{ section.settings.highlight_text }}</div>
        {% endif %}
      </div>

      <div class="premium-fashion-hero__media reveal">
        <div class="premium-fashion-hero__media-frame">
          {% if section.settings.desktop_image != blank or section.settings.mobile_image != blank %}
            <picture>
              {% if section.settings.mobile_image != blank %}
                <source media="(max-width: 749px)" srcset="{{ section.settings.mobile_image | image_url: width: 1400 }}">
              {% endif %}
              {% if section.settings.desktop_image != blank %}
                <img
                  class="premium-fashion-hero__image"
                  src="{{ section.settings.desktop_image | image_url: width: 2200 }}"
                  alt="{{ section.settings.desktop_image.alt | escape }}"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                >
              {% elsif section.settings.mobile_image != blank %}
                <img
                  class="premium-fashion-hero__image"
                  src="{{ section.settings.mobile_image | image_url: width: 1400 }}"
                  alt="{{ section.settings.mobile_image.alt | escape }}"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                >
              {% endif %}
            </picture>
          {% else %}
            <div class="premium-fashion-hero__media-placeholder" role="img" aria-label="Luxury fashion editorial preview"></div>
          {% endif %}

          <div class="premium-fashion-hero__scroll-indicator" aria-hidden="true">
            <span>Scroll</span>
            <i></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{{ 'section-premium-fashion-hero.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Ultra Premium Hero Banner",
  "tag": "section",
  "class": "section-premium-fashion-hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Small label",
      "default": "Luxury essentials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The new standard of modern luxury"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Refined tailoring, elevated comfort, and sculptural silhouettes designed to stand apart."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover a fashion experience crafted for the modern wardrobe and the most discerning taste.</p>"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Floating badge text",
      "default": "New arrival"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Shop collection"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Explore lookbook"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f7efe7"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#b68c4b"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "default": 0.18
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "hero_height",
      "label": "Image height",
      "min": 320,
      "max": 1200,
      "step": 10,
      "default": 720
    },
    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable animations",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature point",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon",
          "default": "✦"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Premium finish"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Thoughtfully crafted with exceptional detail."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ultra Premium Hero Banner"
    }
  ]
}
{% endschema %}
