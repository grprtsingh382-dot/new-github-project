{{ 'section-premium-fashion-hero.css' | asset_url | stylesheet_tag }}

<section
  class="premium-fashion-hero"
  data-section-id="{{ section.id }}"
  data-section-type="premium-fashion-hero"
  style="--hero-surface: {{ section.settings.background_color | default: '#0b0a09' }}; --hero-accent: {{ section.settings.accent_color | default: '#b68c4b' }};"
>
  <div class="premium-fashion-hero__backdrop" aria-hidden="true"></div>

  <div class="page-width premium-fashion-hero__container">
    <div class="premium-fashion-hero__grid">
      <div class="premium-fashion-hero__content premium-fashion-hero__content--{{ section.settings.content_alignment | default: 'left' }}">
        {% if section.settings.eyebrow != blank %}
          <p class="premium-fashion-hero__eyebrow reveal reveal--item">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h1 class="premium-fashion-hero__heading reveal reveal--item">{{ section.settings.heading }}</h1>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <p class="premium-fashion-hero__subheading reveal reveal--item">{{ section.settings.subheading }}</p>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="premium-fashion-hero__description reveal reveal--item">{{ section.settings.description }}</div>
        {% endif %}

        {% if section.settings.primary_button_label != blank or section.settings.secondary_button_label != blank %}
          <div class="premium-fashion-hero__actions reveal reveal--item">
            {% if section.settings.primary_button_label != blank and section.settings.primary_button_link != blank %}
              <a
                class="premium-fashion-hero__button premium-fashion-hero__button--primary js-magnetic"
                href="{{ section.settings.primary_button_link }}"
              >
                <span>{{ section.settings.primary_button_label }}</span>
              </a>
            {% endif %}

            {% if section.settings.secondary_button_label != blank and section.settings.secondary_button_link != blank %}
              <a
                class="premium-fashion-hero__button premium-fashion-hero__button--secondary"
                href="{{ section.settings.secondary_button_link }}"
              >
                <span>{{ section.settings.secondary_button_label }}</span>
              </a>
            {% endif %}
          </div>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="premium-fashion-hero__highlights" role="list">
            {% for block in section.blocks %}
              {% if block.type == 'feature' %}
                <article class="premium-fashion-hero__feature reveal reveal--item" {{ block.shopify_attributes }} role="listitem">
                  <span class="premium-fashion-hero__feature-icon" aria-hidden="true">{{ block.settings.icon }}</span>
                  <div>
                    <h2 class="premium-fashion-hero__feature-title">{{ block.settings.title }}</h2>
                    <p class="premium-fashion-hero__feature-text">{{ block.settings.text }}</p>
                  </div>
                </article>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="premium-fashion-hero__media reveal">
        <div class="premium-fashion-hero__media-frame">
          {% if section.settings.hero_image != blank %}
            <img
              class="premium-fashion-hero__image"
              src="{{ section.settings.hero_image | image_url: width: 1800 }}"
              alt="{{ section.settings.hero_image.alt | escape }}"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            >
          {% else %}
            <div class="premium-fashion-hero__media-placeholder" role="img" aria-label="Luxury fashion editorial preview"></div>
          {% endif %}

          {% if section.settings.small_image != blank %}
            <div class="premium-fashion-hero__overlay-card">
              <img
                class="premium-fashion-hero__overlay-image"
                src="{{ section.settings.small_image | image_url: width: 900 }}"
                alt="{{ section.settings.small_image.alt | escape }}"
                loading="lazy"
                decoding="async"
              >
              {% if section.settings.highlight_text != blank %}
                <p class="premium-fashion-hero__overlay-text">{{ section.settings.highlight_text }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>

    {% if section.blocks.size > 0 %}
      <div class="premium-fashion-hero__stats" role="list">
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
            <div class="premium-fashion-hero__stat reveal reveal--item" {{ block.shopify_attributes }} role="listitem">
              <p class="premium-fashion-hero__stat-value">{{ block.settings.value }}</p>
              <p class="premium-fashion-hero__stat-label">{{ block.settings.label }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{{ 'section-premium-fashion-hero.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Premium Fashion Hero",
  "tag": "section",
  "class": "section-premium-fashion-hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Luxury Essentials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted for the modern wardrobe"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Elevated tailoring, sculptural silhouettes, and timeless details."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover a new era of fashion where quality meets distinction.</p>"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "small_image",
      "label": "Floating detail image"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Floating highlight text",
      "default": "Limited release"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Shop collection"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Explore story"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0b0a09"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#b68c4b"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature point",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon",
          "default": "✦"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Premium finish"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Thoughtfully crafted with exceptional detail."
        }
      ]
    },
    {
      "type": "stat",
      "name": "Statistic",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "01"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Season launch"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Fashion Hero"
    }
  ]
}
{% endschema %}
